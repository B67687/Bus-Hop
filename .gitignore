# gitaccept: block everything by default, whitelist explicitly
# Prevents accidentally tracking stray files (build artifacts, IDE files, temp files)
/*
!/.gitignore
!/.editorconfig
!.github/
!.github/**
!/app/
!/app/**
!/data/
!/data/**
!/docs/
!/docs/**
!/domain/
!/domain/**
!/gradle/
!/gradle/**
!/mcp/
!/mcp/**
!/detekt.yml
!/*.gradle.kts
!/gradle.properties
!/gradlew
!/gradlew.bat
!/lint.xml
!/*.lockfile
!/*.md
!/LICENSE
!/CREDITS.md
!/settings.gradle.kts

# Sub-blacklists — within whitelisted dirs, re-block what we don't want
build/
*.apk
*.ap_
*.aab
*.dex
*.class
local.properties
*.log
*.iml
.DS_Store
Thumbs.db
*.jks
*.keystore
app/keystore.jks
docs/index.html
mcp/node_modules/
